rules_version = '2';

// ============================================================
// PousadaGest — Regras de segurança do Firebase Storage
// Publique em: Firebase Console → Storage → Rules → colar e Publicar
// (ou: firebase deploy --only storage)
// ============================================================
service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de cada pousada: tenants/{tenantId}/hero|rooms|categories/arquivo.jpg
    match /tenants/{tenantId}/{allPaths=**} {
      // Leitura pública — as fotos aparecem na página de reservas sem login.
      allow read: if true;

      // Só quem pertence ao tenant (e está ativo) pode enviar/trocar/remover fotos.
      allow write: if request.auth != null
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.tenantId == tenantId
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.status == 'active'
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
